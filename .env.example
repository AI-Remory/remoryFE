# Local development
# Vite runs at http://localhost:5173 and calls the deployed backend directly.
VITE_API_BASE_URL=http://141.164.48.128:8000/api/v1
VITE_WS_BASE_URL=ws://141.164.48.128:8000/api/v1

# Same-server/Nginx deployment
# Use relative paths when the frontend and backend are served from the same origin.
# Configure these values in the deployment environment instead of the local values above.
# VITE_API_BASE_URL=/api/v1
# VITE_WS_BASE_URL=/api/v1
